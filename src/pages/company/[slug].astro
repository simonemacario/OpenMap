---
import companies from "../../data/companies.json";
import meta from "../../data/meta.json";
import "../../styles/global.css";

export function getStaticPaths() {
  return companies.map((c) => ({ params: { slug: c.slug }, props: { company: c } }));
}

const { company } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p) => `${base}/${p.replace(/^\//, "")}`;
const isPlaceholder = (meta.dataStatus || "").startsWith("PLACEHOLDER");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": company.type === "institution" ? "Organization" : "Organization",
  name: company.name,
  url: company.website || undefined,
  description: company.description,
  address: { "@type": "PostalAddress", addressLocality: company.city, addressRegion: company.region, addressCountry: "MY" },
  areaServed: "MY",
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{company.name} — OpenMap</title>
    <meta name="description" content={company.description} />
    <set:html set:html={`<script type="application/ld+json">${JSON.stringify(jsonLd)}</script>`} />
  </head>
  <body>
    <div class="wrap">
      <nav class="crumbs">
        <a href={link("")}>The State of Italian Business in Malaysia</a>
        <span class="dot">›</span>
        <a href={link("companies")}>All companies</a>
      </nav>

      {isPlaceholder && (
        <p class="notice">⚠ Sample record for layout only — not verified data.</p>
      )}

      <header class="co-head">
        <p class="kicker">{company.type === "institution" ? "Institution" : "Company"} · {company.sector}</p>
        <h1>{company.name}</h1>
        <p class="summary">{company.description}</p>
      </header>

      <dl class="facts">
        <div><dt>Industry</dt><dd>{company.industry}</dd></div>
        <div><dt>Sector</dt><dd>{company.sector}</dd></div>
        <div><dt>Location</dt><dd>{company.city}{company.region ? `, ${company.region}` : ""}, Malaysia</dd></div>
        <div><dt>Present in Malaysia since</dt><dd>{company.firstSeen}</dd></div>
        {company.employees && <div><dt>Size (local, approx.)</dt><dd>{company.employees}</dd></div>}
        {company.website && <div><dt>Website</dt><dd><a href={company.website} rel="noopener noreferrer" target="_blank">{company.website.replace(/^https?:\/\//, "")}</a></dd></div>}
        {company.leadership?.length > 0 && (
          <div>
            <dt>Leadership</dt>
            <dd>{company.leadership.map((p) => `${p.role}${p.name && p.name !== "—" ? ` — ${p.name}` : ""}`).join("; ")}</dd>
          </div>
        )}
      </dl>

      <p class="method">
        Something wrong or out of date?{" "}
        <a href={`mailto:${meta.correctionsEmail}?subject=OpenMap correction: ${encodeURIComponent(company.name)}`}>Send a correction</a>.
      </p>

      <footer>
        <a href={link("companies")}>← Back to all companies</a> · OpenMap, open data, free to cite.
      </footer>
    </div>
  </body>
</html>
